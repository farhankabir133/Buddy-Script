# Copy this file to `.env` (or `.env.local`) and fill in real values.
# All four are REQUIRED — the app fails fast on startup if any are missing.

# Supabase project URL (Settings -> API -> Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (Settings -> API -> anon public)
# Safe to expose to the browser; used for RLS-authenticated data queries.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service-role key (Settings -> API -> service_role)
# SERVER-ONLY. Bypasses RLS. Never expose with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret used to sign session JWTs. Generate with: openssl rand -hex 32
# IMPORTANT: must equal the Supabase project JWT secret (Settings -> API ->
# JWT Secret) so Supabase accepts the forwarded session token for RLS.
JWT_SECRET=replace-me-with-a-long-random-secret
